[Unit]
Description=Local Dub LLM v1 worker
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/localdub
EnvironmentFile=/opt/localdub/localdub.env
ExecStart=/usr/bin/python3 /opt/localdub/worker.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
